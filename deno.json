{
  "nodeModulesDir": "auto",
  "tasks": {
    "run": "deno run -A script.ts",
    "dev": "deno run --watch main.ts"
    "test": "deno run -A npm:vitest"
  },
  "imports": {
    "@effect/language-service": "npm:@effect/language-service@^0.73.1",
    "@effect/vitest": "npm:@effect/vitest@^0.27.0",
    "@std/assert": "jsr:@std/assert@1",
    "effect": "npm:effect@^3.19.16",
    "vitest": "npm:vitest@^4.0.18"
  },
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  }
}
